{
  "$schema": "https://opencode.ai/config.json",
  "tui": {
    "scroll_speed": 10,
    "scroll_acceleration": {
      "enabled": true
    }
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      ".env.example": "allow"
    },
    "bash": {
      "*": "allow"
    }
  },
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        "qwen2.5-coder-14b-local": {
          "name": "Qwen2.5-Coder-14B (local)",
          "limit": {
            "context": 8192,
            "output": 2048
          }
        }
      }
    }
  }
}
